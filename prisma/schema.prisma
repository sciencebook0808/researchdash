// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ROADMAP
// ─────────────────────────────────────────────

model RoadmapStep {
  id          String   @id @default(cuid())
  phase       Int
  title       String
  description String   @db.Text
  status      StepStatus @default(PENDING)
  order       Int      @default(0)
  tasks       RoadmapTask[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([phase])
  @@index([status])
}

model RoadmapTask {
  id          String   @id @default(cuid())
  title       String
  completed   Boolean  @default(false)
  stepId      String
  step        RoadmapStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([stepId])
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// ─────────────────────────────────────────────
// DOCUMENTATION
// ─────────────────────────────────────────────

model DocumentationPage {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @db.Text
  section   String
  order     Int      @default(0)
  tags      String[]
  versions  DocVersion[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([section])
  @@index([slug])
}

model DocVersion {
  id        String   @id @default(cuid())
  content   String   @db.Text
  version   Int
  pageId    String
  page      DocumentationPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([pageId])
}

// ─────────────────────────────────────────────
// DATASETS
// ─────────────────────────────────────────────

model Dataset {
  id               String   @id @default(cuid())
  name             String
  description      String?  @db.Text
  sourceUrl        String?
  datasetType      DatasetType
  numSamples       Int?
  sizeBytes        BigInt?
  preprocessStatus PreprocStatus @default(RAW)
  tags             String[]
  format           String?
  license          String?
  experiments      Experiment[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([datasetType])
  @@index([preprocessStatus])
}

enum DatasetType {
  CODE
  TEXT
  INSTRUCTION
  QA
  MIXED
}

enum PreprocStatus {
  RAW
  CLEANING
  CLEANED
  FORMATTED
  AUGMENTED
  READY
}

// ─────────────────────────────────────────────
// EXPERIMENTS
// ─────────────────────────────────────────────

model Experiment {
  id              String   @id @default(cuid())
  name            String
  description     String?  @db.Text
  baseModel       String
  datasetId       String?
  dataset         Dataset? @relation(fields: [datasetId], references: [id])
  status          ExperimentStatus @default(PENDING)
  config          Json?
  loraRank        Int?
  loraAlpha       Int?
  batchSize       Int?
  learningRate    Float?
  epochs          Int?
  evalLoss        Float?
  evalAccuracy    Float?
  bleuScore       Float?
  pass1Score      Float?
  logs            ExperimentLog[]
  modelVersions   ModelVersion[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([datasetId])
}

model ExperimentLog {
  id           String   @id @default(cuid())
  experimentId String
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  step         Int
  loss         Float?
  learningRate Float?
  message      String?
  createdAt    DateTime @default(now())

  @@index([experimentId])
}

enum ExperimentStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ─────────────────────────────────────────────
// MODEL VERSIONS
// ─────────────────────────────────────────────

model ModelVersion {
  id               String   @id @default(cuid())
  name             String
  version          String
  description      String?  @db.Text
  parameterCount   BigInt?
  experimentId     String?
  experiment       Experiment? @relation(fields: [experimentId], references: [id])
  quantization     QuantizationType?
  deploymentFormat String?
  bleuScore        Float?
  pass1Score       Float?
  humanEval        Float?
  mmluScore        Float?
  fileSizeBytes    BigInt?
  isDeployed       Boolean  @default(false)
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([version])
  @@index([experimentId])
}

enum QuantizationType {
  NONE
  INT8
  INT4
  GPTQ
  GGUF
  AWQ
}

// ─────────────────────────────────────────────
// NOTES
// ─────────────────────────────────────────────

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  tags      String[]
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pinned])
}
